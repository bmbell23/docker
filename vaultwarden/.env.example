# Copy this file to .env and replace all placeholder values before first start.

# Host port for Vaultwarden web UI
VAULTWARDEN_PORT=8222

# Used in invite emails and links shown by the app
# Keep this on your Tailscale IP/hostname unless you add a reverse proxy and TLS.
DOMAIN=http://100.69.184.113:8222

# Initial account creation flow:
# - Set to true for first startup so you can create users
# - Set to false after all intended accounts are created
SIGNUPS_ALLOWED=true

# Disable public invite endpoint by default
INVITATIONS_ALLOWED=false

# Admin panel protection (required)
# Generate with: openssl rand -base64 48
ADMIN_TOKEN=replace-with-a-long-random-secret

# Optional SMTP settings for email invites/password reset.
# Leave all of these commented out unless you are configuring SMTP.
# SMTP_HOST=smtp.example.com
# SMTP_FROM=vaultwarden@example.com
# SMTP_PORT=587
# SMTP_SECURITY=starttls
# SMTP_USERNAME=vaultwarden@example.com
# SMTP_PASSWORD=replace-with-smtp-password

# Security and behavior
WEBSOCKET_ENABLED=true
PUSH_ENABLED=false
SHOW_PASSWORD_HINT=false
LOG_LEVEL=warn
