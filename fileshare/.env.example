# Copy to .env and customize for each one-off share

# Host path to share. Can be a directory OR a single file.
# Examples:
# SHARE_HOST_PATH=/mnt/storage/drop/share-folder
# SHARE_HOST_PATH=/mnt/storage/drop/report.pdf
SHARE_HOST_PATH=/path/to/file-or-directory

# Container-side mount path.
# For a file:      /share/real-filename.ext   (preserves filename on download)
# For a directory: /share
SHARE_CONTAINER_PATH=/share

# Optional page title in miniserve UI
MINISERVE_TITLE=Temporary File Share

# Cloudflare named tunnel token (required only for named tunnel mode)
# Not used by Quick Tunnel mode.
CF_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token

# Public hostname routed to named tunnel in Cloudflare Zero Trust.
# Not consumed directly by docker-compose, documented here for clarity.
# Not used by Quick Tunnel mode.
CF_TUNNEL_HOSTNAME=share.example.com

# Optional basic auth credentials for auth override compose file.
# Format: username:password OR username:sha256:<hash>
# Only used when docker-compose.auth.yml is included.
MINISERVE_AUTH=alice:change-me-now
